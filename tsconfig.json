{
    "compilerOptions": {
        "strict": true,
        "noEmit": true,
        "moduleResolution": "NodeNext",
        "allowImportingTsExtensions": true,

        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,

        // Allows using top-level await
        "module": "NodeNext",
        "target": "es2023",

        // Ensure the TypeScript compiler detects node types from `@types/node`
        "types": ["node"]
    }
}
